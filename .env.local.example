# Gigi OS — variables locales (copier vers .env.local, ne jamais committer)

# Supabase (client — clés publiques uniquement)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IA — serveur uniquement (jamais NEXT_PUBLIC_, jamais côté navigateur)
AI_PROVIDER=
OPENAI_API_KEY=
AI_MODEL=

# Rappel sécurité :
# - Ne commite jamais .env.local
# - Ne colle jamais OPENAI_API_KEY dans le chat ou le code versionné
# - Redémarre `npm run dev` après modification de .env.local
